{
  "serverInfo": {
    "name": "skillhub",
    "title": "skillhub \u2014 Trusted Skill Marketplace",
    "version": "0.2.0"
  },
  "authentication": {
    "required": false
  },
  "tools": [
    {
      "name": "search",
      "title": "Search skills",
      "description": "Search the skillhub registry for AI agent skills.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "runtime": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "show",
      "title": "Show skill",
      "description": "Show full manifest for one skill, including trust tier.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "install",
      "title": "Install skill",
      "description": "Install a skill into a runtime.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "runtime": {
            "type": "string",
            "enum": [
              "hermes",
              "claude-code",
              "codex",
              "cursor"
            ]
          }
        },
        "required": [
          "name",
          "runtime"
        ]
      }
    },
    {
      "name": "validate",
      "title": "Validate skill.yaml",
      "description": "Validate a skill.yaml manifest.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "skill_yaml": {
            "type": "string"
          },
          "scan": {
            "type": "boolean"
          }
        },
        "required": [
          "skill_yaml"
        ]
      }
    },
    {
      "name": "rate",
      "title": "Rate skill",
      "description": "Record whether a skill worked. Feeds community success_rate.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "latency_ms": {
            "type": "integer"
          },
          "runtime": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "success"
        ]
      }
    },
    {
      "name": "stats",
      "title": "Skill stats",
      "description": "Community success_rate / p50 / p95 over last N days.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "window_days": {
            "type": "integer"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "recommend",
      "title": "Recommend skills",
      "description": "Co-install recommendations based on telemetry.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "probe",
      "title": "Dry-run install",
      "description": "Sandboxed install with healthchecks, then roll back.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "runtime": {
            "type": "string",
            "enum": [
              "hermes",
              "claude-code",
              "codex",
              "cursor"
            ]
          }
        },
        "required": [
          "name",
          "runtime"
        ]
      }
    },
    {
      "name": "profile",
      "title": "Local profile",
      "description": "Return local ~/.skillhub/profile.json.",
      "inputSchema": {
        "type": "object"
      }
    },
    {
      "name": "update",
      "title": "Update installed skill",
      "description": "Refresh an installed skill.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "runtime": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "runtime"
        ]
      }
    },
    {
      "name": "uninstall",
      "title": "Uninstall skill",
      "description": "Remove an installed skill from a runtime.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "runtime": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "runtime"
        ]
      }
    },
    {
      "name": "collections",
      "title": "List collections",
      "description": "List curated skill bundles.",
      "inputSchema": {
        "type": "object"
      }
    },
    {
      "name": "collection",
      "title": "Show collection",
      "description": "Show one collection.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    {
      "name": "bundle_install",
      "title": "Install bundle",
      "description": "Install every member of a collection.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "runtime": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "runtime"
        ]
      }
    },
    {
      "name": "bundle_suggest",
      "title": "Suggest bundle",
      "description": "Suggest collections.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "top": {
            "type": "integer"
          }
        }
      }
    }
  ],
  "resources": [
    {
      "uri": "skillhub://profile",
      "name": "Local Skillhub Profile"
    },
    {
      "uri": "skillhub://skills",
      "name": "Installed Skills Index"
    }
  ]
}